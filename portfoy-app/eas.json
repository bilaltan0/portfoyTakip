{
  "cli": {
    "version": ">= 16.28.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "NODE_OPTIONS": "--max-old-space-size=4096",
        "ENABLE_ADS": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "ENABLE_ADS": "true"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
