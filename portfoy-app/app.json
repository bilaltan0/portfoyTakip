{
  "expo": {
    "name": "PortföyMate",
    "slug": "portfoymate",
    "version": "1.0.14",
    "orientation": "portrait",
    "icon": "./assets/PortfoyMate_Icon_512.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/PortfoyMate_Icon_512.png",
      "resizeMode": "contain",
      "backgroundColor": "#0891B2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bilaltan.portfoyapp"
    },
    "android": {
      "package": "com.bilaltan.portfoyapp",
      "versionCode": 24,
      "adaptiveIcon": {
        "foregroundImage": "./assets/PortfoyMate_Icon_512.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/PortfoyMate_Icon_512.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "2.0.21"
          }
        }
      ]
    ],
    "react-native-google-mobile-ads": {
      "android_app_id": "ca-app-pub-3940256099942544~3347511713",
      "ios_app_id": "ca-app-pub-3940256099942544~1458002511"
    },
    "extra": {
      "eas": {
        "projectId": "63f32f4e-ecd4-49ac-97d7-aa56f58a62eb"
      },
      "enableTestAds": false
    }
  }
}